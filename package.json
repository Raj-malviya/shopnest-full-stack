{
  "name": "shopnest-full-stack",
  "version": "1.0.0",
  "description": "",
  "keywords": [
    "raj",
    "malviya",
    "microservice"
  ],
  "license": "ISC",
  "author": "raj malviya",
  "type": "commonjs",
  "main": "backend/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "install-all": "npm install && npm --prefix frontend install && npm --prefix backend install",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm --prefix frontend start",
    "dev:server": "npm --prefix backend run dev",
    "build": "npm --prefix frontend run build",
    "render-build": "npm install && npm --prefix backend install && npm --prefix frontend install && npm --prefix frontend run build",
    "start": "node backend/index.js",
    "seed": "npm --prefix backend run seed"
  },
  "dependencies": {
    "concurrently": "^10.0.3"
  }
}
